# LLM provider: local | openrouter (default: local)
# LLM_PROVIDER=local

# LLM (OpenAI-compatible endpoint)
# Local: LLM_BASE_URL=http://localhost:1234/v1
# Remote LLM (TailScale, порт 8005): LOCAL_AI_LLM_BASE_URL + LLM_PROVIDER=local
# OpenRouter: LLM_PROVIDER=openrouter, LLM_API_KEY — база по умолчанию https://openrouter.ai/api/v1
#   Модель по умолчанию в коде: openai/gpt-5.4-nano — см. https://openrouter.ai/openai/gpt-5.4-nano
#   Не оставляйте LLM_BASE_URL=localhost при openrouter — перекроет OpenRouter.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=default
LLM_API_KEY=not-needed
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# Remote LLM service base (OpenAI-compatible /v1); overrides LLM_BASE_URL when set
# LOCAL_AI_LLM_BASE_URL=http://YOUR_TAILSCALE_HOST:8005/v1

# OpenRouter (optional leaderboards / app attribution)
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=Plague-InGG

# Memory
MEMORY_MAX_CHARS=8000
REFLECTION_ENABLED=true

# RAG / Embedding — BGE-M3 OpenAI-compatible (порт 9001); путь /v1/embeddings подставляется в memory/rag.py
LOCAL_AI_EMBEDDING_BASE_URL=http://YOUR_TAILSCALE_HOST:9001

# Fail the turn if RAG or reflection errors (default: log warning only)
# RAG_STRICT=false
# REFLECTION_STRICT=false

# Context / safety (optional)
# TOOL_RESULT_MAX_CHARS=24000   # 0 = no trim of tool outputs in LLM messages
# SHELL_POLICY=deny             # deny | strict | off
# SHELL_ALLOW_PREFIXES=git ,pytest ,uv ,python ,echo ,ls ,cat ,head ,wc ,pwd
# WRITE_FILE_SHRINK_GUARD=0     # 1 = refuse writes that shrink file below WRITE_FILE_MIN_RATIO
# WRITE_FILE_MIN_RATIO=0.35
# WRITE_FILE_MIN_LEN=200
# LLM_LOG_USAGE=1               # append usage to evolution/llm_usage.jsonl when API returns usage

LOCAL_AI_EMBEDDING_TIMEOUT=30

# Brave Search (https://brave.com/search/api/ — для доступа к интернету)
BRAVE_API_KEY=your-brave-api-key-here

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

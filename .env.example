# Ekaterina v2 — copy to .env and fill in
# Supports: TELEGRAM_BOT_TOKEN / telegram_bot_token, BRAVE_API_KEY / api_key_brave_search, GITHUB_TOKEN / github_token

# --- Required (secrets) ---
TELEGRAM_BOT_TOKEN=
BRAVE_API_KEY=   # or api_key_brave_search= — для web_search

# --- Optional (GitHub: higher rate limits, required for github_search_code) ---
GITHUB_TOKEN=

# --- LLM (замените на свои хосты: primary 80B, secondary 35B) ---
LOCAL_AI_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_AI_LLM_SECONDARY_BASE_URL=http://localhost:8005/v1

# --- ASR, Embedding, Reranker ---
LOCAL_AI_ASR_BASE_URL=http://localhost:8001
LOCAL_AI_EMBEDDING_BASE_URL=http://localhost:9001
LOCAL_AI_RERANKER_BASE_URL=http://localhost:9002

# --- Capability zones (Blueprint) ---
# AUTO_APPROVE_ADD_TOOL: allow add_tool without human approval (Orange zone)
AUTO_APPROVE_ADD_TOOL=true

# --- Metacognitive monitor (Blueprint) ---
# METACOGNITIVE_CHECK: 80B evaluates confidence/repetition before tool execution
METACOGNITIVE_CHECK=false

# --- Forgetting curves (Blueprint) ---
MEMORY_DECAY_FACTOR=0.99
MEMORY_SALIENCE_THRESHOLD=0.3

# --- Memory Hierarchy (Blueprint 2.1) ---
# MEMORY_RECALL_ENABLED: semantic search in session-history, evolution-log before each round
MEMORY_RECALL_ENABLED=true

# --- Optional ---
LOCAL_AI_LLM_TIMEOUT=120
# MAX_ROUNDS: 0 = без лимита (SAFETY_CAP 5000)
MAX_ROUNDS=0
# PARALLEL_TOOLS: true = выполнять 2+ tool calls параллельно
PARALLEL_TOOLS=false
# CONSCIOUSNESS_INTERVAL: секунды между циклами consciousness_daemon
CONSCIOUSNESS_INTERVAL=300
